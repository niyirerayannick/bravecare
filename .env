# BraveCare Outreach — Environment Configuration
# Copy this file and fill in real values before deployment.

# Email settings (Gmail example — use an App Password, not your account password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=BraveCare Outreach <noreply@bravecare.org>

# Application
SECRET_KEY=django-insecure-bravecare-outreach-dev-key-change-in-production-xyz123
DEBUG=True
